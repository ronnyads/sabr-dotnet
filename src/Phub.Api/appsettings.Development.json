{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RefreshToken": {
    "RequireHttps": false,
    "CookieDomain": ""
  },
  "LoginProtection": {
    "IpRateLimit": {
      "Enabled": true,
      "PermitLimit": 120,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "CredentialLock": {
      "Enabled": true,
      "MaxAttempts": 20,
      "AttemptWindowMinutes": 10,
      "LockDurationMinutes": 1
    }
  },
  "Cors": {
    "DevOrigin": "http://localhost:4200"
  },
  "DocumentLookup": {
    "Mode": "PublicCnpj"
  },
  "PublicCnpj": {
    "BaseUrl": "https://brasilapi.com.br/",
    "TimeoutSeconds": 5,
    "CacheMinutes": 30,
    "Provider": "brasilapi"
  },
  "MercadoLivre": {
    "ClientId": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "ClientSecret": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "AuthBaseUrl": "https://auth.mercadolivre.com.br",
    "ApiBaseUrl": "https://api.mercadolibre.com",
    "TokenUrl": "https://api.mercadolibre.com/oauth/token",
    "RedirectUri": "http://localhost:5250/api/v1/client/integrations/mercadolivre/callback",
    "ClientPortalBaseUrl": "http://localhost:4200",
    "SyncLookbackDays": 2,
    "NightlyReconcileLookbackDays": 7,
    "ReservationTtlHours": 24,
    "DefaultTimeZoneId": "America/Sao_Paulo",
    "DefaultCutoffLocalTime": "12:00",
    "WebhookSecret": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "Features": {
      "Publish": true,
      "Webhook": true,
      "Labels": false,
      "Shipments": true,
      "Mabang": true,
      "Reconcile": true,
      "SlaByMode": true
    },
    "Resilience": {
      "RetryMaxAttempts": 4,
      "RetryBaseDelayMs": 250,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerDurationSeconds": 30
    },
    "Mabang": {
      "BaseUrl": "http://localhost:8080",
      "LabelEndpoint": "/api/v1/labels",
      "ApiKeyHeader": "X-Api-Key",
      "ApiKey": "__SET_VIA_USER_SECRETS_OR_ENV__",
      "TimeoutSeconds": 15
    },
    "CategoryMappings": {
      "beleza/depilacao": "MLB32137",
      "MLB:beleza/depilacao": "MLB32137",
      "tratamentos-de-beleza": "MLB277912",
      "MLB:tratamentos-de-beleza": "MLB277912",
      "geladeiras-termicas": "MLB18272",
      "MLB:geladeiras-termicas": "MLB18272"
    }
  },
  "TikTokShop": {
    "AppKey": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "AppSecret": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "RedirectUri": "http://localhost:5250/api/v1/client/integrations/tiktokshop/callback",
    "AuthBaseUrl": "https://auth.tiktok-shops.com",
    "AuthorizePath": "/oauth/authorize",
    "ApiBaseUrl": "https://open-api.tiktokglobalshop.com",
    "TokenPath": "/api/token/getAccessToken",
    "RefreshTokenPath": "/api/token/refreshToken",
    "Scopes": "seller.base,product.read,product.write,order.read",
    "ClientPortalBaseUrl": "http://localhost:4200"
  },
  "Shopee": {
    "PartnerId": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "PartnerKey": "__SET_VIA_USER_SECRETS_OR_ENV__",
    "RedirectUri": "http://localhost:5250/api/v1/client/integrations/shopee/callback",
    "AuthorizationBaseUrl": "https://open.shopee.com.br",
    "AuthorizationPath": "/auth",
    "ApiBaseUrl": "https://partner.shopeemobile.com",
    "AuthType": "seller",
    "ClientPortalBaseUrl": "http://localhost:4200",
    "SyncLookbackDays": 2,
    "Features": {
      "Sync": true,
      "Publish": false
    }
  },
  "ConnectionStrings": {
    "Default": "Host=127.0.0.1;Port=5432;Database=sabr3;Username=sabr_user;Password=postgres"
  },
  "ProductVariantBackfill": {
    "Enabled": true,
    "RunOnStartup": true,
    "IntervalMinutes": 10,
    "BatchSize": 200
  }
}
