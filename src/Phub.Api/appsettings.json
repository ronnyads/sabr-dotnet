{
  "App": {
    "Name": "PHUB 3.0",
    "Version": "0.4.0"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "BackgroundWorkers": {
    "Enabled": false
  },
  "Database": {
    "Host": "127.0.0.1",
    "Port": 5432,
    "Name": "phub3",
    "User": "phub_user",
    "Password": "__SET_VIA_ENV_OR_SECRET__",
    "Pooling": true,
    "MinPoolSize": 0,
    "MaxPoolSize": 100,
    "SslMode": "Disable",
    "Schema": "public"
  },
  "Protheus": {
    "BaseUrl": "http://protheus.api/rest",
    "Username": "api_user_phub",
    "Password": "secure_protheus_pwd",
    "TimeoutSeconds": 30
  },
  "Storage": {
    "BasePath": "storage",
    "PublicBaseUrl": ""
  },
  "Jwt": {
    "Issuer": "PHUB3",
    "Audience": "PHUB3",
    "Key": "__SET_VIA_ENV_OR_SECRET__",
    "Secret": "__SET_VIA_ENV_OR_SECRET__",
    "AccessTokenMinutes": 120
  },
  "Bootstrap": {
    "Enabled": true,
    "AdminKey": "PHUB3_BOOTSTRAP_9F3C8A27_8DD3_4F1D_8B18_70C2851C6C22"
  },
  "RefreshToken": {
    "Days": 30,
    "CookieName": "phub_rt",
    "CookieDomain": ".marketplaceonline.site",
    "RequireHttps": true
  },
  "LoginProtection": {
    "IpRateLimit": {
      "Enabled": true,
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "CredentialLock": {
      "Enabled": true,
      "MaxAttempts": 5,
      "AttemptWindowMinutes": 10,
      "LockDurationMinutes": 15
    }
  },
  "DocumentLookup": {
    "Mode": "PublicCnpj"
  },
  "PublicCnpj": {
    "BaseUrl": "https://brasilapi.com.br/",
    "TimeoutSeconds": 5,
    "CacheMinutes": 30,
    "Provider": "brasilapi"
  },
  "MercadoLivre": {
    "ClientId": "__SET_VIA_ENV_OR_SECRETS_ML_CLIENT_ID__",
    "ClientSecret": "__SET_VIA_ENV_OR_SECRETS_ML_CLIENT_SECRET__",
    "AuthBaseUrl": "https://auth.mercadolivre.com.br",
    "ApiBaseUrl": "https://api.mercadolibre.com",
    "TokenUrl": "https://api.mercadolibre.com/oauth/token",
    "RedirectUri": "http://localhost:5250/api/v1/client/integrations/mercadolivre/callback",
    "ClientPortalBaseUrl": "",
    "SyncLookbackDays": 2,
    "NightlyReconcileLookbackDays": 7,
    "ReservationTtlHours": 24,
    "DefaultTimeZoneId": "America/Sao_Paulo",
    "DefaultCutoffLocalTime": "12:00",
    "WebhookSecret": "",
    "Features": {
      "Publish": false,
      "Webhook": false,
      "Labels": false,
      "Shipments": false,
      "Mabang": false,
      "Reconcile": false,
      "SlaByMode": true
    },
    "Resilience": {
      "RetryMaxAttempts": 3,
      "RetryBaseDelayMs": 300,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerDurationSeconds": 30
    },
    "Mabang": {
      "BaseUrl": "http://localhost:8080",
      "LabelEndpoint": "/api/v1/labels",
      "ApiKeyHeader": "X-Api-Key",
      "ApiKey": "",
      "TimeoutSeconds": 15
    }
  },
  "ProductVariantBackfill": {
    "Enabled": true,
    "RunOnStartup": true,
    "IntervalMinutes": 30,
    "BatchSize": 500
  },
  "Cors": {
    "AllowedDomain": "marketplaceonline.site",
    "DevOrigin": "http://localhost:4200",
    "AllowedOrigins": [
      "https://app.marketplaceonline.site",
      "https://admin.marketplaceonline.site",
      "https://marketplaceonline.site",
      "https://www.marketplaceonline.site"
    ]
  },
  "TinyErp": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "https://localhost:5001/api/v1/client/integrations/tinyerp/callback",
    "ApiBaseUrl": "https://api.tiny.com.br/public-api/v3",
    "AuthBaseUrl": "https://accounts.tiny.com.br/realms/tiny/protocol/openid-connect"
  },
  "Shopify": {
    "ClientId": "__SET_VIA_ENV_OR_SECRET__",
    "ClientSecret": "__SET_VIA_ENV_OR_SECRET__",
    "RedirectUri": "http://localhost:5250/api/v1/client/integrations/shopify/callback",
    "Scopes": "read_orders,read_products,read_inventory",
    "ClientPortalBaseUrl": "http://localhost:4200"
  },
  "TikTokShop": {
    "AppKey": "__SET_VIA_ENV_OR_SECRET__",
    "AppSecret": "__SET_VIA_ENV_OR_SECRET__",
    "RedirectUri": "http://localhost:5250/api/v1/client/integrations/tiktokshop/callback",
    "AuthBaseUrl": "https://auth.tiktok-shops.com",
    "AuthorizePath": "/oauth/authorize",
    "ApiBaseUrl": "https://open-api.tiktokglobalshop.com",
    "TokenPath": "/api/token/getAccessToken",
    "RefreshTokenPath": "/api/token/refreshToken",
    "Scopes": "seller.authorization.info,seller.shop.info,seller.product.basic,seller.global_product.category.info,seller.global_product.info,seller.product.write,seller.global_product.write,seller.order.info",
    "ClientPortalBaseUrl": "http://localhost:4200",
    "Features": {
      "Webhook": false,
      "Sync": true,
      "Publish": false
    }
  },
  "AllowedOrigins": "https://app.marketplaceonline.site,https://admin.marketplaceonline.site,https://marketplaceonline.site,https://www.marketplaceonline.site",
  "ConnectionStrings": {
    "Default": "__SET_VIA_ENV_OR_SECRET__",
    "Redis": "__SET_VIA_ENV_OR_SECRET__"
  }
}
