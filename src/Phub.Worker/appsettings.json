{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Database": {
    "Host": "127.0.0.1",
    "Port": 5432,
    "Name": "phub3",
    "User": "phub_user",
    "Password": "__SET_VIA_ENV_OR_SECRET__",
    "Pooling": true,
    "MinPoolSize": 0,
    "MaxPoolSize": 20,
    "SslMode": "Disable",
    "Schema": "public"
  },
  "Protheus": {
    "BaseUrl": "http://protheus.api/rest",
    "Username": "api_user_phub",
    "Password": "secure_protheus_pwd",
    "TimeoutSeconds": 30
  },
  "MercadoLivre": {
    "ClientId": "__SET_VIA_ENV_OR_SECRETS_ML_CLIENT_ID__",
    "ClientSecret": "__SET_VIA_ENV_OR_SECRETS_ML_CLIENT_SECRET__",
    "AuthBaseUrl": "https://auth.mercadolivre.com.br",
    "ApiBaseUrl": "https://api.mercadolibre.com",
    "TokenUrl": "https://api.mercadolibre.com/oauth/token",
    "RedirectUri": "https://app.sabr.com/api/v1/client/integrations/mercadolivre/callback",
    "SyncLookbackDays": 2,
    "NightlyReconcileLookbackDays": 7,
    "ReservationTtlHours": 24,
    "DefaultTimeZoneId": "America/Sao_Paulo",
    "DefaultCutoffLocalTime": "12:00",
    "WebhookSecret": "__SET_VIA_ENV_OR_SECRET__",
    "Features": {
      "Publish": false,
      "Webhook": false,
      "Labels": false,
      "Shipments": false,
      "Mabang": false,
      "Reconcile": false,
      "SlaByMode": true
    },
    "Resilience": {
      "RetryMaxAttempts": 3,
      "RetryBaseDelayMs": 300,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerDurationSeconds": 30
    },
    "Mabang": {
      "BaseUrl": "http://localhost:8080",
      "LabelEndpoint": "/api/v1/labels",
      "ApiKeyHeader": "X-Api-Key",
      "ApiKey": "",
      "TimeoutSeconds": 15
    }
  },
  "ProductVariantBackfill": {
    "Enabled": true,
    "RunOnStartup": true,
    "IntervalMinutes": 30,
    "BatchSize": 500
  },
  "Workers": {
    "Enabled": true
  },
  "ConnectionStrings": {
    "Default": "__SET_VIA_ENV_OR_SECRET__"
  }
}
